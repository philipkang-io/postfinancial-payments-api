PORT=3000
NODE_ENV=development
API_VERSION=v1

# Database (simulated - not actually used in this demo)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postfinancial_payments

# Payment Gateway Settings
PAYMENT_GATEWAY_URL=https://gateway.postfinancial.example.com
PAYMENT_GATEWAY_API_KEY=demo_key_12345

# Security
JWT_SECRET=your_jwt_secret_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
